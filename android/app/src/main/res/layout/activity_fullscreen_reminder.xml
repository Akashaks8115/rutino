<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_fullscreen_bg"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Emoji / Icon -->
        <FrameLayout
            android:id="@+id/flEmojiContainer"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/circle_glow_bg"
            android:layout_marginBottom="40dp">
            
            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🔥"
                android:textSize="96sp" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Routine Reminder"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp"
            android:text="It's time to complete your habit."
            android:textColor="#94A3B8"
            android:lineSpacingExtra="4dp"
            android:textSize="18sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Primary Action -->
        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#5465FF"
            android:text="Mark Day Completed ✔️"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:elevation="8dp"
            android:textAllCaps="false" />

        <!-- Secondary Action -->
        <Button
            android:id="@+id/btnSnooze"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:background="@android:color/transparent"
            android:text="Remind Me in 15 Mins ⏰"
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            style="?android:attr/borderlessButtonStyle" />

    </LinearLayout>
</RelativeLayout>
